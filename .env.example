# Copia este archivo a .env (o exporta las variables) y rellena los valores.
# ¡Nunca subas el .env real a GitHub!
TELEGRAM_TOKEN=123456:ABC-tu-token-de-botfather

# Cuenta POR DEFECTO del bot en andaluh.ushahidi.io: se usa cuando la persona
# elige "seguir sin cuenta propia" en Telegram. Crea una cuenta normal solo
# para esto (p. ej. "Telegram Paisaje Andaluz"), así en Ushahidi se distingue
# qué aportaciones llegaron desde Telegram.
USHAHIDI_EMAIL=cuenta-telegram@ejemplo.com
USHAHIDI_PASSWORD=tu-contraseña
